{
    "name": "Github Html Preview (Local)",
    "description": "Preview HTML files on GitHub fully locally. Content and your GitHub session never leave your browser.",
    "version": "5.7",
    "manifest_version": 3,

    "permissions": ["storage", "unlimitedStorage", "scripting", "contextMenus"],
    "host_permissions" : ["https://github.com/*", "https://*.githubusercontent.com/*"],

    "icons": {
      "16": "icon/16.png",
      "32": "icon/32.png",
      "48": "icon/48.png",
      "128": "icon/128.png"
    },

    "web_accessible_resources": [
      {
        "resources": ["icon/*.png"],
        "matches": ["https://github.com/*"]
      }
    ],

    "action": {
      "default_popup": "popup/popup.html"
    },

    "background": {
        "service_worker": "background.js"
    },

    "sandbox": {
        "pages": ["preview/sandbox.html"]
    },

    "content_scripts": [
      {
          "matches": ["https://github.com/*.html"],
          "js": ["html-page-content.js"]
      }
    ],

    "commands" : {
        "preview": {
            "suggested_key": {
                "default": "Ctrl+Shift+Y",
                "mac": "Command+Shift+Y"
            },
            "description": "Preview Html"
        }
    }
 }
